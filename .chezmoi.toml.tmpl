{{- /* Prompts on `chezmoi init`; declares the PS interpreter so chezmoi can run .ps1 scripts on Windows. */ -}}
{{- $name := promptStringOnce . "name" "Full name" -}}
{{- $email := promptStringOnce . "email" "Git email" -}}

[data]
    name  = {{ $name | quote }}
    email = {{ $email | quote }}

[interpreters.ps1]
    command = "powershell"
    args = ["-NoProfile", "-ExecutionPolicy", "Bypass"]
