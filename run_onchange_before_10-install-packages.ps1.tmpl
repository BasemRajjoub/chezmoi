# install-packages — re-runs ONLY when this rendered content changes (chezmoi hashes it).
# Scoop no-ops already-installed apps; buckets + winget are guarded. Non-admin safe.
$ErrorActionPreference = "Stop"

if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    Invoke-RestMethod get.scoop.sh | Invoke-Expression
}

$haveBuckets = (scoop bucket list).Name
{{ range .scoop.buckets -}}
if ($haveBuckets -notcontains "{{ .name }}") { scoop bucket add {{ .name }}{{ if hasKey . "url" }} {{ .url }}{{ end }} }
{{ end -}}

{{- $extra := list -}}
{{- if hasKey .scoop "byHost" -}}{{- if hasKey .scoop.byHost .chezmoi.hostname -}}{{- $extra = index .scoop.byHost .chezmoi.hostname -}}{{- end -}}{{- end -}}
scoop install {{ range .scoop.apps }}{{ . }} {{ end }}{{ range $extra }}{{ . }} {{ end }}

{{ range .winget.apps -}}
if (-not (winget list --id {{ .id }} -e 2>$null | Select-String "{{ .id }}")) {
    winget install -e --id {{ .id }} --accept-source-agreements --accept-package-agreements
}
{{ if hasKey . "assertExe" -}}
if (-not (Test-Path (Join-Path $env:USERPROFILE '{{ .assertExe }}'))) {
    Write-Error "winget {{ .id }} installed but expected exe missing: {{ .assertExe }} (needs admin? source down?)"
}
{{ end -}}
{{ end -}}
